
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Default rule: block all reads and writes by default for security.
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Avatars: Public read, owner write.
    // Allows anyone to view a profile photo, but only the user to change it.
    match /avatars/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Payment Proofs: User can upload payment proofs for their own orders.
    match /payment_proofs/{userId}/{orderId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Report Evidence: Users can upload evidence for their reports.
    // Only the user who created the report can write. Reading is also restricted to the owner.
    // Admin access should be handled via a backend using admin SDKs.
    match /reports/{userId}/{reportId}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
