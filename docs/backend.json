{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile in the application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID from Firebase Authentication."
        },
        "numericId": {
          "type": "string",
          "description": "A randomly generated 8-digit numeric ID for the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "URL of the user's profile picture."
        },
        "phoneNumber": {
          "type": "string",
          "description": "The user's phone number."
        },
        "balance": {
          "type": "number",
          "description": "The user's account balance."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user profile was created."
        },
        "paymentMethods": {
            "type": "array",
            "description": "A list of the user's linked payment methods.",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "The name of the payment method (e.g., PhonePe, Paytm)."
                    },
                    "upiId": {
                        "type": "string",
                        "description": "The user's UPI ID for that payment method."
                    }
                },
                "required": ["name", "upiId"]
            }
        }
      },
      "required": ["uid", "numericId", "balance", "createdAt"]
    }
  },
  "auth": {
    "providers": ["email", "phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores public profile information for each user."
    }
  }
}
